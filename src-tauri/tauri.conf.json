{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "BentoDesk",
  "version": "1.2.4",
  "identifier": "com.bentodesk.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BentoDesk",
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "visible": true,
        "additionalBrowserArgs": "--enable-features=UseSkiaRenderer,CanvasOopRasterization --disable-features=msWebOOUI,msPdfOOUI"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' bentodesk: asset: data:; font-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1NzBGRDQ1Njk0NTlGQ0MKUldUTW4wVnBSZjF3bFowM3ZLRkprNE9JbHpIbTdsNjNxUDUrcm5ERXk4bFA4aUJLUUliVS9NYVoK",
      "endpoints": [
        "https://github.com/ZRainbow1275/bentodesk/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/guardian"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "startMenuFolder": "BentoDesk",
        "installerHooks": "nsis-hooks.nsi"
      }
    },
    "copyright": "Copyright © 2026 方寒. All rights reserved.",
    "publisher": "方寒"
  }
}
